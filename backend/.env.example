# Backend environment configuration
# Copy this file to backend/.env and fill in your values

# Adapter selection: "seed" (demo data) or "flash_alpha" (live data)
GEX_ADAPTER=seed

# Flash Alpha API key — required only when GEX_ADAPTER=flash_alpha
# Get your key at https://flashalpha.com
FLASH_ALPHA_API_KEY=your_api_key_here

# AI Chat — OpenRouter (required for the Ask FlashAlpha widget)
# Get your key at https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_key_here
# Optional: override the default model (default: deepseek/deepseek-v4-flash)
# OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# Optional: Pydantic Logfire observability (agent runs, tool calls, token cost)
# Get your token at https://logfire.pydantic.dev
# LOGFIRE_TOKEN=your_logfire_token_here

# Optional tuning (defaults shown)
CACHE_TTL_SECONDS=30
SNAPSHOT_INTERVAL_SECONDS=60
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
